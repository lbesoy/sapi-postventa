# ============================================
# CONFIGURACIÓN DE CONEXIÓN A SAP BUSINESS ONE
# ============================================
# Renombra este archivo a ".env" e ingresa los datos reales de tu servidor SAP.

# 1. URL de la API de SAP (Service Layer)
# Generalmente corre en el puerto 50000 y requiere HTTPS
SAP_SL_URL=https://TU_SERVIDOR_SAP:50000/b1s/v1

# 2. Base de Datos de la Compañía (CompanyDB)
# El nombre técnico de la base de datos de la empresa en SAP B1
SAP_COMPANY_DB=SBODEMOMX

# 3. Credenciales de Integración
# (Se recomienda crear un usuario específico en SAP para este sistema, ej: API_EUROREP)
SAP_USER=manager
SAP_PASSWORD=tu_contraseña_secreta

# 4. Puerto local para el servidor Node.js
PORT=3000

# 5. Configuración de Supabase
# URL y Clave Anónima o Service Role de tu proyecto en Supabase
SUPABASE_URL=https://tu_proyecto.supabase.co
SUPABASE_KEY=tu_anon_o_service_role_key

